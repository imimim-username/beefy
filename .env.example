# ── Deployer private key (never commit .env) ──────────────────────────────────
DEPLOYER_PK=0xYOUR_PRIVATE_KEY_HERE

# ── RPC URLs per network (add any networks you use) ───────────────────────────
RPC_ETH=https://ethereum.publicnode.com
RPC_BSC=https://bsc-dataseed.binance.org/
RPC_POLYGON=https://polygon-rpc.com
RPC_ARBITRUM=https://arb1.arbitrum.io/rpc
RPC_OPTIMISM=https://mainnet.optimism.io
RPC_BASE=https://mainnet.base.org
RPC_AVAX=https://api.avax.network/ext/bc/C/rpc
RPC_FANTOM=https://rpc.ftm.tools
RPC_CELO=https://forno.celo.org
RPC_MOONBEAM=https://rpc.api.moonbeam.network
RPC_CRONOS=https://evm.cronos.org

# ── Server ─────────────────────────────────────────────────────────────────────
PORT=8788
